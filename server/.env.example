# Copy this file to ".env" and fill in real values.
# Ask a teammate (or check your shared password manager) for the actual
# DATABASE_URL and JWT_SECRET so everyone connects to the same database.

GROQ_API_KEY=your-groq-api-key-here
FINNHUB_API_KEY=your-finnhub-api-key-here
PORT=3001
JWT_SECRET=ask-a-teammate-for-the-shared-secret
DATABASE_URL=ask-a-teammate-for-the-shared-connection-string
